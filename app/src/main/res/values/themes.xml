<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AICompanion" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#00F0FF</item>
        <item name="android:windowBackground">#0A0E1A</item>
        <item name="android:statusBarColor">#0A0E1A</item>
    </style>

    <style name="CustLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#00F0FF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="CustRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>
</resources>
