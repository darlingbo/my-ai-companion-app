<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/space_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎨 Design Your AI"
        android:textColor="#00F0FF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:paddingTop="16dp"
        android:paddingBottom="6dp" />

    <!-- Live preview -->
    <WebView
        android:id="@+id/previewWeb"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Customization options -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView style="@style/CustLabel" android:text="SKIN" />
            <LinearLayout android:id="@+id/rowSkin" style="@style/CustRow" />

            <TextView style="@style/CustLabel" android:text="HAIR" />
            <LinearLayout android:id="@+id/rowHair" style="@style/CustRow" />

            <TextView style="@style/CustLabel" android:text="OUTFIT" />
            <LinearLayout android:id="@+id/rowShirt" style="@style/CustRow" />

            <TextView style="@style/CustLabel" android:text="PANTS" />
            <LinearLayout android:id="@+id/rowPants" style="@style/CustRow" />

            <TextView style="@style/CustLabel" android:text="EYES" />
            <LinearLayout android:id="@+id/rowEyes" style="@style/CustRow" />

            <Button
                android:id="@+id/saveLookBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✓ SAVE MY AVATAR"
                android:background="@drawable/neon_button"
                android:textColor="#0A0E1A"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="14dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
