<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/space_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖"
                android:textSize="34sp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="0dp">
                <TextView
                    android:id="@+id/headerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AURA"
                    android:textColor="#00F0FF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEURAL COMPANION v2.1"
                    android:textColor="#7B2FFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● ONLINE"
                android:textColor="#00F0FF"
                android:textSize="11sp"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="◢◤ Works ONLINE and OFFLINE ◢◤"
            android:textColor="#5A6080"
            android:textSize="11sp"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <!-- BOND LEVEL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/bondText"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="💖 Bond Level 1 — New Friend"
                android:textColor="#FF6AD5" android:textSize="14sp" android:textStyle="bold"
                android:gravity="center" />
            <TextView
                android:id="@+id/moodText"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Mood: 🙂 Content"
                android:textColor="#7B2FFF" android:textSize="12sp"
                android:gravity="center" android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- PROFILE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="◉  IDENTITY" android:textColor="#00F0FF"
                android:textSize="12sp" android:textStyle="bold"
                android:letterSpacing="0.15" android:layout_marginBottom="12dp" />
            <EditText android:id="@+id/nameInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Your name" android:textColor="#E0F7FF" android:textColorHint="#4A5070"
                android:backgroundTint="#00F0FF" android:inputType="textPersonName"
                android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/aiNameInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="AI's name" android:textColor="#E0F7FF" android:textColorHint="#4A5070"
                android:backgroundTint="#00F0FF" android:inputType="textPersonName" />
        </LinearLayout>

        <!-- CONNECTION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡  NEURAL LINK (cloud brain)" android:textColor="#00F0FF"
                android:textSize="12sp" android:textStyle="bold"
                android:letterSpacing="0.1" android:layout_marginBottom="12dp" />
            <EditText android:id="@+id/keyInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Groq API key (gsk_...)" android:textColor="#E0F7FF" android:textColorHint="#4A5070"
                android:backgroundTint="#00F0FF" android:inputType="text" />
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Optional — without it, offline brain still works!"
                android:textColor="#5A6080" android:textSize="10sp" android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- AVATAR CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✦  HOLOGRAM FORM" android:textColor="#00F0FF"
                android:textSize="12sp" android:textStyle="bold"
                android:letterSpacing="0.15" android:layout_marginBottom="12dp" />
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:weightSum="5">
                <TextView android:id="@+id/emoji1"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp"
                    android:text="🤖" android:textSize="28sp" android:gravity="center"
                    android:background="@drawable/emoji_selected" android:layout_margin="3dp" />
                <TextView android:id="@+id/emoji2"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp"
                    android:text="👽" android:textSize="28sp" android:gravity="center"
                    android:background="@drawable/emoji_unselected" android:layout_margin="3dp" />
                <TextView android:id="@+id/emoji3"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp"
                    android:text="🛸" android:textSize="28sp" android:gravity="center"
                    android:background="@drawable/emoji_unselected" android:layout_margin="3dp" />
                <TextView android:id="@+id/emoji4"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp"
                    android:text="⚡" android:textSize="28sp" android:gravity="center"
                    android:background="@drawable/emoji_unselected" android:layout_margin="3dp" />
                <TextView android:id="@+id/emoji5"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="58dp"
                    android:text="✨" android:textSize="28sp" android:gravity="center"
                    android:background="@drawable/emoji_unselected" android:layout_margin="3dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- STATUS -->
        <TextView android:id="@+id/statusText"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="#FFB800" android:textSize="12sp"
            android:gravity="center" android:layout_marginVertical="6dp" />

        <!-- ACTIONS -->
        <Button android:id="@+id/overlayBtn"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="① GRANT HOLOGRAM ACCESS" android:background="@drawable/card_bg"
            android:textColor="#00F0FF" android:textSize="13sp" android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <Button android:id="@+id/startBtn"
            android:layout_width="match_parent" android:layout_height="60dp"
            android:text="② ACTIVATE ⚡" android:background="@drawable/neon_button"
            android:textColor="#0A0E1A" android:textStyle="bold" android:textSize="17sp"
            android:letterSpacing="0.1" android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2">
            <Button android:id="@+id/saveBtn"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:text="◈ SAVE" android:background="@drawable/card_bg"
                android:textColor="#E0F7FF" android:layout_marginEnd="5dp" />
            <Button android:id="@+id/stopBtn"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp"
                android:text="◼ DEACTIVATE" android:background="@drawable/card_bg"
                android:textColor="#FF4A6A" android:layout_marginStart="5dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
