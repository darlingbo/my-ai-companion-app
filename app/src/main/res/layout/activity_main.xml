<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#212121">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🤖"
            android:textSize="56sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My AI Companion"
            android:textColor="#ECECEC"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A floating AI that lives on your screen, talks to you, and asks how you're doing — even when locked."
            android:textColor="#8E8EA0"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Your name" android:textColor="#ECECEC" android:textSize="13sp" />
        <EditText android:id="@+id/nameInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="e.g. Stephen" android:textColor="#ECECEC" android:textColorHint="#666"
            android:backgroundTint="#10A37F" android:inputType="textPersonName"
            android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AI's name" android:textColor="#ECECEC" android:textSize="13sp" />
        <EditText android:id="@+id/aiNameInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="e.g. Aura" android:textColor="#ECECEC" android:textColorHint="#666"
            android:backgroundTint="#10A37F" android:inputType="textPersonName"
            android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Groq API Key (free from console.groq.com)" android:textColor="#ECECEC" android:textSize="13sp" />
        <EditText android:id="@+id/keyInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="gsk_..." android:textColor="#ECECEC" android:textColorHint="#666"
            android:backgroundTint="#10A37F" android:inputType="text"
            android:layout_marginBottom="18dp" />

        <Button android:id="@+id/saveBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="💾 Save Settings" android:backgroundTint="#2F2F2F"
            android:textColor="#ECECEC" android:layout_marginBottom="10dp" />

        <TextView android:id="@+id/statusText"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="#FBBF24" android:textSize="13sp"
            android:gravity="center" android:layout_marginVertical="12dp" />

        <Button android:id="@+id/overlayBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="1️⃣ Allow Float Permission" android:backgroundTint="#3B82F6"
            android:textColor="#FFFFFF" android:layout_marginBottom="10dp" />

        <Button android:id="@+id/startBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="2️⃣ START MY AI 🚀" android:backgroundTint="#10A37F"
            android:textColor="#FFFFFF" android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button android:id="@+id/stopBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="⛔ Stop AI" android:backgroundTint="#3D0D0D"
            android:textColor="#F87171" />

    </LinearLayout>
</ScrollView>
